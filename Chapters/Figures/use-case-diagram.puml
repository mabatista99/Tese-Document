@startuml use-case-diagram

left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam usecase {
    BackgroundColor White
    BorderColor Black
}

actor "End User" as EU

rectangle "IoT Monitoring Platform" {
    (UC01: Monitor Devices\nin Real Time) as UC01
    (UC02: Automate Anomaly\nDetection) as UC02
    (UC03: Review and\nAcknowledge Alerts) as UC03
    (UC04: Investigate\nDevice History) as UC04
    (UC05: Monitor Devices During\nConnectivity Loss) as UC05
}

EU -- UC01
EU -- UC02
EU -- UC03
EU -- UC04
EU -- UC05

@enduml
